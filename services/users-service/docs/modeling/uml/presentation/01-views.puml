@startuml PresentationViews

skinparam classAttributeIconSize 0

' === MAIN FRAME (from com.medical.ui) ===
package "com.medical.ui" {
  class MainFrame <<view>> #SkyBlue;line:Black
}

' === USER MANAGEMENT PANEL (from com.medical.ui.panel) ===
package "com.medical.ui.panel" {
  class UserManagementPanel <<view>> #SkyBlue;line:Black
}

' === USER FORM DIALOG (from com.medical.ui.dialog) ===
package "com.medical.ui.dialog" {
  class UserFormDialog <<view>> #SkyBlue;line:Black
}

' === USER TABLE MODEL (from com.medical.ui.model) ===
package "com.medical.ui.model" {
  class UserTableModel <<view>> #SkyBlue;line:Black
}

' === OBSERVER VIEWS (from com.medical.ui.panel) ===
package "com.medical.ui.panel" {
  class AppointmentView <<view>> #SkyBlue;line:Black
  class CalendarView <<view>> #SkyBlue;line:Black
  class NotificationView <<view>> #SkyBlue;line:Black
  class DashboardView <<view>> #SkyBlue;line:Black
}

' === EXTERNAL DEPENDENCIES ===
package "com.medical.service" {
  interface UserService <<interface>> #aliceblue;line:blue
}

package "com.medical.dto" {
  class UserDTO <<dto>> #LightCyan;line:Black
}

package "com.medical.enums" {
  enum UserRole {
    ADMINISTRATOR
    PATIENT
    PHYSICIAN
    THERAPIST
    SCHEDULER
  }
  
  enum UserStatus {
    ACTIVE
    INACTIVE
    PENDING
  }
}

package "com.medical.event" {
  class ClinicEventBus <<singleton>> #PaleGreen;line:Black
  interface ClinicObserver <<interface>> #aliceblue;line:blue
}

' === RELATIONSHIPS WITH CARDINALITIES ===
UserManagementPanel "1" --> "1" UserService : "uses"
UserManagementPanel "1" --> "1" UserTableModel : "uses"
UserManagementPanel "0..1" --> "0..1" UserFormDialog : "opens"
UserFormDialog "1" --> "1" UserDTO : "manipulates"
UserFormDialog "1" --> "1" UserRole : "uses"
UserFormDialog "1" --> "1" UserStatus : "uses"
UserTableModel "0..*" --> "0..1" UserDTO : "displays"

' === OBSERVER PATTERN RELATIONSHIPS ===
CalendarView "1" --> "1" ClinicObserver : "implements"
NotificationView "1" --> "1" ClinicObserver : "implements"
DashboardView "1" --> "1" ClinicObserver : "implements"
AppointmentView "1" --> "1" ClinicObserver : "implements"

ClinicObserver "0..*" --> "1" ClinicEventBus : "subscribes to"
CalendarView "1" --> "1" ClinicEventBus : "updates via"
NotificationView "1" --> "1" ClinicEventBus : "updates via"
DashboardView "1" --> "1" ClinicEventBus : "updates via"
AppointmentView "1" --> "1" ClinicEventBus : "updates via"

note "Presentation Layer: Views + Observer Pattern" as N1

@enduml