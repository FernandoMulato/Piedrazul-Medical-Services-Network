@startuml PresentationViewsOperations

skinparam classAttributeIconSize 0

' === MAIN FRAME ===
class MainFrame <<view>> #SkyBlue;line:Black {
  +MainFrame()
  -initializeUI(): void
  -createMenuBar(): JMenuBar
  -createMainTabs(): JTabbedPane
}

' === USER MANAGEMENT PANEL ===
class UserManagementPanel <<view>> #SkyBlue;line:Black {
  -userService: UserService
  -tableModel: UserTableModel
  -table: JTable
  -sorter: TableRowSorter<UserTableModel>
  -searchField: JTextField
  -statusLabel: JLabel
  +UserManagementPanel()
  -initializeUI(): void
  -createTopPanel(): JPanel
  -createTablePanel(): JScrollPane
  -createBottomPanel(): JPanel
  -loadUsers(): void
  -filterTable(): void
  -showCreateDialog(): void
  -showEditDialog(): void
  -deactivateSelectedUser(): void
  -updateStatus(String): void
  -createIcon(String): Icon
}

' === USER FORM DIALOG ===
class UserFormDialog <<view>> #SkyBlue;line:Black {
  -user: UserDTO
  -confirmed: boolean
  -documentField: JTextField
  -firstNameField: JTextField
  -lastNameField: JTextField
  -emailField: JTextField
  -phoneField: JTextField
  -roleCombo: JComboBox<UserRole>
  -statusCombo: JComboBox<UserStatus>
  +UserFormDialog(Frame, UserDTO)
  -initializeUI(): void
  -populateFields(): void
  -saveUser(): void
  -showError(String): void
  +isConfirmed(): boolean
  +getUser(): UserDTO
}

' === USER TABLE MODEL ===
class UserTableModel <<view>> #SkyBlue;line:Black {
  -users: List<UserDTO>
  +UserTableModel()
  +UserTableModel(List<UserDTO>)
  +getRowCount(): int
  +getColumnCount(): int
  +getColumnName(int): String
  +getValueAt(int, int): Object
  +getColumnClass(int): Class<?>
  +isCellEditable(int, int): boolean
  +setUsers(List<UserDTO>): void
  +getUsers(): List<UserDTO>
  +getUserAt(int): UserDTO
  +addUser(UserDTO): void
  +updateUser(int, UserDTO): void
  +removeUser(int): void
  +clear(): void
}

@enduml