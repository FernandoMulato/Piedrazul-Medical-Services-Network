@startuml InfrastructureRepositoriesOperations

skinparam classAttributeIconSize 0

' === CONNECTION PROVIDER (DIP) ===
interface ConnectionProvider <<interface>> #Gold;line:Black {
  +getConnection(): Connection
  +initializeDatabase(): void
  +closeConnection(): void
  +getDbPath(): String
}

class SQLiteConnectionProvider <<implementation>> #SkyBlue;line:Black {
  -instance: SQLiteConnectionProvider
  -connection: Connection
  -dbPath: String
  +getInstance(): SQLiteConnectionProvider
  +getConnection(): Connection
  -createConnection(): Connection
}

' === PERSISTENCE STRATEGY (OCP) ===
interface PersistenceStrategy <<interface,T>> #LightYellow;line:Black {
  +getSQL(): String
  +setParameters(T, PreparedStatement): void
  +postExecute(T, PreparedStatement): void
  +isInsert(): boolean
}

' User Strategies
class UserInsertStrategy #Wheat {
  +getSQL(): String
  +setParameters(User, PreparedStatement): void
  +postExecute(User, PreparedStatement): void
  +isInsert(): true
}

class UserUpdateStrategy #Wheat {
  +getSQL(): String
  +setParameters(User, PreparedStatement): void
  +postExecute(User, PreparedStatement): void
  +isInsert(): false
}

' UserPersistenceStrategy Selector
class UserPersistenceStrategy #LightCyan {
  -insertStrategy: UserInsertStrategy
  -updateStrategy: UserUpdateStrategy
  +selectStrategy(User): PersistenceStrategy
}

' Appointment Strategies
class AppointmentInsertStrategy #Wheat {
  +getSQL(): String
  +setParameters(Appointment, PreparedStatement): void
  +postExecute(Appointment, PreparedStatement): void
  +isInsert(): true
}

class AppointmentUpdateStrategy #Wheat {
  +getSQL(): String
  +setParameters(Appointment, PreparedStatement): void
  +postExecute(Appointment, PreparedStatement): void
  +isInsert(): false
}

' AppointmentPersistenceStrategy Selector
class AppointmentPersistenceStrategy #LightCyan {
  -insertStrategy: AppointmentInsertStrategy
  -updateStrategy: AppointmentUpdateStrategy
  +selectStrategy(Appointment): PersistenceStrategy
}

' === REPOSITORIES ===
class UserRepository <<repository>> #PaleGreen;line:Black {
  -connectionProvider: ConnectionProvider
  -persistenceStrategy: UserPersistenceStrategy
  +save(User): User
  +findById(Long): Optional<User>
  +findAll(): List<User>
  +findByDocumentNumber(String): Optional<User>
  +findByEmail(String): Optional<User>
  +deleteById(Long): void
  -mapResultSetToUser(ResultSet): User
}

class AppointmentRepository <<repository>> #PaleGreen;line:Black {
  -connectionProvider: ConnectionProvider
  -persistenceStrategy: AppointmentPersistenceStrategy
  +save(Appointment): Appointment
  +findById(Long): Optional<Appointment>
  +findAll(): List<Appointment>
  +findByPatientId(Long): List<Appointment>
  +findByProfessionalId(Long): List<Appointment>
  +findByStatus(AppointmentStatus): List<Appointment>
  +findByScheduledDateTimeBetween(LocalDateTime, LocalDateTime): List<Appointment>
  +deleteById(Long): void
  -mapResultSetToAppointment(ResultSet): Appointment
}

' === ENUMS ===
enum AppointmentStatus #LightBlue;line:Black {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

note "Operations: Only attributes and methods\nRelations see 01-repositories.puml" as N1

@enduml