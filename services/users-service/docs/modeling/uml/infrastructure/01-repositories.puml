@startuml InfrastructureRepositories

skinparam classAttributeIconSize 0

' === CONNECTION PROVIDER (DIP - Interfaz) ===
package "com.medical.db" {
  interface ConnectionProvider <<interface>> #Gold;line:Black
}

' === CONNECTION PROVIDER IMPLEMENTATION ===
package "com.medical.db" {
  class SQLiteConnectionProvider <<implementation>> #SkyBlue;line:Black
}

' === DATABASE CONNECTION LEGACY (Deprecated) ===
package "com.medical.db" {
  class DatabaseConnection <<deprecated>> #LightGray;line:gray
}

' === USER REPOSITORY ===
package "com.medical.repository" {
  class UserRepository <<repository>> #PaleGreen;line:Black
}

' === APPOINTMENT REPOSITORY ===
package "com.medical.repository" as pkg_repo {
  class AppointmentRepository <<repository>> #PaleGreen;line:Black
}

' === PERSISTENCE STRATEGY (OCP) ===
package "com.medical.repository.strategy" {
  interface PersistenceStrategy <<interface>> #LightYellow;line:Black
}

package "com.medical.repository.strategy" {
  class UserInsertStrategy
  class UserUpdateStrategy
  class AppointmentInsertStrategy
  class AppointmentUpdateStrategy
}

' === ENTITY ===
package "com.medical.model" {
  class User
  class Appointment
}

' === RELATIONSHIPS ===
' DIP: Repositories dependen de abstracción ConnectionProvider
UserRepository "1" --> "1" ConnectionProvider : "uses (DIP)"
AppointmentRepository "1" --> "1" ConnectionProvider : "uses (DIP)"

' ConnectionProvider implementado por SQLiteConnectionProvider
ConnectionProvider <|.. SQLiteConnectionProvider : "implements"

' DatabaseConnection es wrapper legacy
DatabaseConnection ..> SQLiteConnectionProvider : "delegates"

' OCP: Repository usa estrategias
UserRepository "1" o-- "1" PersistenceStrategy : "uses (OCP)"
AppointmentRepository "1" o-- "1" PersistenceStrategy : "uses (OCP)"

' Estrategias implementan PersistenceStrategy
PersistenceStrategy <|.. UserInsertStrategy
PersistenceStrategy <|.. UserUpdateStrategy
PersistenceStrategy <|.. AppointmentInsertStrategy
PersistenceStrategy <|.. AppointmentUpdateStrategy

' Entities persistidas
UserRepository "0..*" --> "0..1" User : "persists"
AppointmentRepository "0..*" --> "0..1" Appointment : "persists"

note "DIP: Dependency Inversion\nOCP: Open/Closed Principle" as N1

@enduml