@startuml ApplicationServicesOperations

skinparam classAttributeIconSize 0

' === USER SERVICE INTERFACE ===
interface UserService <<interface>> #aliceblue;line:blue {
  +create(UserDTO): UserDTO
  +update(Long, UserDTO): UserDTO
  +findById(Long): Optional<UserDTO>
  +findAll(): List<UserDTO>
  +findByDocumentNumber(String): Optional<UserDTO>
  +findByEmail(String): Optional<UserDTO>
  +deactivate(Long): void
  +updateStatus(Long, UserStatus): void
}

' === USER SERVICE IMPLEMENTATION ===
class UserServiceImpl <<service>> #PaleGreen;line:Black {
  -userRepository: UserRepository
  -userFactory: UserFactory
  +create(UserDTO): UserDTO
  +update(Long, UserDTO): UserDTO
  +findById(Long): Optional<UserDTO>
  +findAll(): List<UserDTO>
  +findByDocumentNumber(String): Optional<UserDTO>
  +findByEmail(String): Optional<UserDTO>
  +deactivate(Long): void
  +updateStatus(Long, UserStatus): void
  -toDTO(User): UserDTO
}

' === APPOINTMENT SERVICE INTERFACE ===
interface AppointmentService <<interface>> #aliceblue;line:blue {
  +create(AppointmentDTO): AppointmentDTO
  +update(Long, AppointmentDTO): AppointmentDTO
  +findById(Long): Optional<AppointmentDTO>
  +findAll(): List<AppointmentDTO>
  +findByPatientId(Long): List<AppointmentDTO>
  +findByProfessionalId(Long): List<AppointmentDTO>
  +findByStatus(AppointmentStatus): List<AppointmentDTO>
  +findByDateRange(LocalDateTime, LocalDateTime): List<AppointmentDTO>
  +cancel(Long): AppointmentDTO
  +reschedule(Long, LocalDateTime): AppointmentDTO
}

' === APPOINTMENT SERVICE IMPLEMENTATION ===
class AppointmentServiceImpl <<service>> #PaleGreen;line:Black {
  -appointmentRepository: AppointmentRepository
  +create(AppointmentDTO): AppointmentDTO
  +update(Long, AppointmentDTO): AppointmentDTO
  +findById(Long): Optional<AppointmentDTO>
  +findAll(): List<AppointmentDTO>
  +findByPatientId(Long): List<AppointmentDTO>
  +findByProfessionalId(Long): List<AppointmentDTO>
  +findByStatus(AppointmentStatus): List<AppointmentDTO>
  +findByDateRange(LocalDateTime, LocalDateTime): List<AppointmentDTO>
  +cancel(Long): AppointmentDTO
  +reschedule(Long, LocalDateTime): AppointmentDTO
  -toEntity(AppointmentDTO): Appointment
  -toDTO(Appointment): AppointmentDTO
}

@enduml