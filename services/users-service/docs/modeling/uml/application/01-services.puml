@startuml ApplicationServices

skinparam classAttributeIconSize 0

' === USER SERVICE INTERFACE (from com.medical.service) ===
package "com.medical.service" {
  interface UserService <<interface>> #aliceblue;line:blue
}

' === USER SERVICE IMPLEMENTATION (from com.medical.service.impl) ===
package "com.medical.service.impl" {
  class UserServiceImpl <<service>> #PaleGreen;line:Black
}

' === APPOINTMENT SERVICE INTERFACE (from com.medical.service) ===
package "com.medical.service" as pkg_service {
  interface AppointmentService <<interface>> #aliceblue;line:blue
}

' === APPOINTMENT SERVICE IMPLEMENTATION (from com.medical.service.impl) ===
package "com.medical.service.impl" as pkg_impl {
  class AppointmentServiceImpl <<service>> #PaleGreen;line:Black
}

' === REPOSITORY INTERFACES (from com.medical.repository) ===
package "com.medical.repository" as pkg_repo {
  interface UserRepository <<interface>> #aliceblue;line:blue
  interface AppointmentRepository <<interface>> #aliceblue;line:blue
}

' === FACTORY (from com.medical.factory) ===
package "com.medical.factory" as pkg_factory {
  interface UserFactory <<interface>> #aliceblue;line:blue
}

' === EVENT BUS (from com.medical.event) ===
package "com.medical.event" as pkg_event {
  class ClinicEventBus <<singleton>> #PaleGreen;line:Black
}

' === RELATIONSHIPS WITH CARDINALITIES ===
UserService <|.. UserServiceImpl : "implements"
AppointmentService <|.. AppointmentServiceImpl : "implements"

UserServiceImpl "1" --> "1" UserRepository : "uses"
UserServiceImpl "1" --> "1" UserFactory : "uses"
AppointmentServiceImpl "1" --> "1" AppointmentRepository : "uses"
AppointmentServiceImpl "1" --> "1" ClinicEventBus : "publishes events"
UserServiceImpl "1" --> "1" ClinicEventBus : "publishes events"

note "Application Layer: Services" as N1

@enduml