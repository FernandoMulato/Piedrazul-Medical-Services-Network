@startuml DomainObserverOperations

skinparam classAttributeIconSize 0

' === EVENT TYPES ===
enum ClinicEventType <<enumeration>> #LightBlue;line:Black {
  +APPOINTMENT_CREATED
  +APPOINTMENT_UPDATED
  +APPOINTMENT_CANCELLED
  +USER_CREATED
  +USER_UPDATED
  +USER_DEACTIVATED
  +STATUS_MESSAGE
}

' === OBSERVER INTERFACE ===
interface ClinicObserver <<interface>> #aliceblue;line:blue {
  +onEvent(event: ClinicEvent): void
}

' === EVENT CLASS ===
class ClinicEvent <<event>> #LightCyan;line:Black {
  -eventType: ClinicEventType
  -data: Object
  -timestamp: LocalDateTime
  -message: String
  +ClinicEvent(eventType: ClinicEventType, data: Object)
  +ClinicEvent(eventType: ClinicEventType, message: String)
  +getEventType(): ClinicEventType
  +getData(): Object
  +getTimestamp(): LocalDateTime
  +getMessage(): String
}

' === EVENT BUS (SINGLETON) ===
class ClinicEventBus <<singleton>> #PaleGreen;line:Black {
  -observers: List<ClinicObserver>
  -instance: ClinicEventBus
  -ClinicEventBus()
  +getInstance(): ClinicEventBus
  +subscribe(observer: ClinicObserver): void
  +unsubscribe(observer: ClinicObserver): void
  +publish(event: ClinicEvent): void
}

@enduml
