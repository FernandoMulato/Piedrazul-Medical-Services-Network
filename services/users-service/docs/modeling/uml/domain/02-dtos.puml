@startuml DomainDTOs

skinparam classAttributeIconSize 0

' === USER DTO (from com.medical.dto) ===
package "com.medical.dto" {
  class UserDTO <<dto>> #LightCyan;line:Black
  class AppointmentDTO <<dto>> #LightCyan;line:Black
}

' === ENUMS (from com.medical.enums) ===
package "com.medical.enums" {
  enum UserRole {
    ADMINISTRATOR
    PATIENT
    PHYSICIAN
    THERAPIST
    SCHEDULER
  }
  
  enum UserStatus {
    ACTIVE
    INACTIVE
    PENDING
  }
  
  enum AppointmentStatus {
    PENDING
    CONFIRMED
    CANCELLED
    COMPLETED
    NO_SHOW
  }
}

' === RELATIONSHIPS WITH CARDINALITIES ===
UserDTO "1" --> "1" UserRole : "has"
UserDTO "1" --> "1" UserStatus : "has"
AppointmentDTO "1" --> "1" AppointmentStatus : "has"

note "Domain Layer: DTOs" as N1

@enduml