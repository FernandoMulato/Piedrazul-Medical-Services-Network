@startuml DomainFactoryOperations

skinparam classAttributeIconSize 0

' === FACTORY INTERFACE ===
interface UserFactory <<interface>> #aliceblue;line:blue {
  +create(UserDTO dto): User
  +getInstance(): UserFactory
}

' === FACTORY IMPLEMENTATION ===
class DefaultUserFactory <<service>> #PaleGreen;line:Black {
  -EMAIL_PATTERN: Pattern
  +create(UserDTO dto): User
  -requireValid(String value, String fieldName): void
  -requireNotNull(Object value, String message): void
  -requireValidEmail(String email): void
  -trimAndValidate(String value, String fieldName): String
}

' === DTO ===
class UserDTO <<dto>> #LightCyan;line:Black {
  -id: Long
  -documentNumber: String
  -firstName: String
  -lastName: String
  -email: String
  -phone: String
  -role: UserRole
  -status: UserStatus
}

' === ENTITY ===
class User <<entity>> #LightYellow;line:Black {
  -id: Long
  -documentNumber: String
  -firstName: String
  -lastName: String
  -email: String
  -phone: String
  -role: UserRole
  -status: UserStatus
  -passwordHash: String
  -createdAt: LocalDateTime
  -updatedAt: LocalDateTime
}

@enduml