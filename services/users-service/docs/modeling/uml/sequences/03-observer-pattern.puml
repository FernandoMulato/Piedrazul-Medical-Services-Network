@startuml SequenceObserverPattern

actor "User" as User

participant "MainFrame" as Frame
participant "AppointmentView" as ApptView
participant "CalendarView" as Calendar
participant "NotificationView" as Notification
participant "DashboardView" as Dashboard

participant "AppointmentController" as Controller
participant "AppointmentService" as Service
participant "ClinicEventBus" as EventBus
participant "ClinicEvent" as Event

participant "UserManagementPanel" as UserPanel

== Observer Subscription (Startup) ==

Frame -> Calendar : new CalendarView()
Frame -> Notification : new NotificationView()
Frame -> Dashboard : new DashboardView()

Calendar -> EventBus : subscribe(this)
Notification -> EventBus : subscribe(this)
Dashboard -> EventBus : subscribe(this)
UserPanel -> EventBus : subscribe(this)

EventBus --> Calendar : observer registered
EventBus --> Notification : observer registered
EventBus --> Dashboard : observer registered
EventBus --> UserPanel : observer registered

== Create Appointment Flow ==

User -> ApptView : fill form data
ApptView -> Controller : requestAppointment(data)
Controller -> Service : createAppointment(dto)

Service -> Service : validate data
Service -> Service : create entity

Service -> Event : new ClinicEvent(APPOINTMENT_CREATED, data)
Service -> EventBus : publish(event)

EventBus -> Calendar : onEvent(event)
EventBus -> Notification : onEvent(event)
EventBus -> Dashboard : onEvent(event)
EventBus -> UserPanel : onEvent(event)

loop "Update each view"
    Calendar -> Calendar : refreshCalendar()
    Notification -> Notification : showNotification("Cita creada")
    Dashboard -> Dashboard : refreshStats()
    UserPanel -> UserPanel : reloadUsers()
end

ApptView --> User : show success message

== Update User Flow ==

User -> UserPanel : click "Create User"
UserPanel -> UserFormDialog : open dialog

User -> UserFormDialog : fill form
UserFormDialog -> UserPanel : user data

UserPanel -> Service : create(UserDTO)

Service -> Service : create entity
Service -> Event : new ClinicEvent(USER_CREATED, user)
Service -> EventBus : publish(event)

EventBus -> Calendar : onEvent(event)
EventBus -> Notification : onEvent(event)
EventBus -> Dashboard : onEvent(event)

Calendar -> Calendar : refreshCalendar()
Notification -> Notification : showNotification("Usuario creado")
Dashboard -> Dashboard : refreshStats()

UserPanel -> UserPanel : reloadUsers()
UserPanel --> User : show success

== Status Message Flow ==

Service -> Event : new ClinicEvent(STATUS_MESSAGE, "Operation successful")
Service -> EventBus : publish(event)

EventBus -> Notification : onEvent(event)
Notification -> Notification : showToast(message)

@enduml
