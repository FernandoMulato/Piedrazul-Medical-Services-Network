@startuml SequenceCreateUser

actor "User" as User
participant "UserManagementPanel" as Panel
participant "UserFormDialog" as Dialog
participant "UserService" as Service
participant "UserFactory" as Factory
participant "UserRepository" as Repo
database "SQLite" as DB

== Create User (UI) ==

User -> Panel : click "Create"
Panel -> Dialog : new UserFormDialog(parent, null)
Dialog --> Panel : dialog.setVisible(true)

User -> Dialog : fill form
Dialog -> Dialog : validate fields
Dialog --> User : show errors if any

User -> Dialog : click "Save"
Dialog -> Dialog : final validation
Dialog --> Panel : dialog.isConfirmed() = true\ndialog.getUser()

== Service (Application) ==

Panel -> Service : create(UserDTO)
Service -> Factory : create(UserDTO)
Factory --> Service : User entity (validated)

Service -> Repo : save(User)
Repo -> DB : INSERT INTO users
DB --> Repo : OK / error
Repo --> Service : User (with generated ID)

Service --> Panel : UserDTO (created)

== Update UI ==

Panel -> Panel : tableModel.addUser(UserDTO)
Panel --> User : show success message

@enduml