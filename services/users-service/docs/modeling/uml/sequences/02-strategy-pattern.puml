@startuml StrategyPatternSequence

title Strategy Pattern - User Persistence Flow

actor User as "Client"
participant "UserManagementPanel" as Panel
participant "UserService" as Service
participant "UserRepository" as Repository
participant "UserPersistenceStrategy" as Selector
participant "PersistenceStrategy<T>" as Strategy
participant "ConnectionProvider" as Provider
database "SQLite DB" as DB

== Save User Flow ==

User -> Panel: create(userDTO)
Panel -> Service: create(userDTO)
Service -> Repository: save(user)

Repository -> Selector: selectStrategy(user)
Selector --> Repository: UserInsertStrategy (id == null)

Repository -> Strategy: getSQL()
Strategy --> Repository: "INSERT INTO users..."

Repository -> Strategy: setParameters(user, stmt)
note right: Binds all user fields\nto PreparedStatement

Repository -> Strategy: isInsert()
Strategy --> Repository: true

Repository -> Provider: getConnection()
Provider -> DB: getConnection()

Repository -> DB: executeUpdate(stmt)

Repository -> Strategy: postExecute(user, stmt)
note right: Extracts generated ID\nfrom ResultSet

Strategy --> Repository: user.setId(generatedId)

Repository --> Service: savedUser
Service --> Panel: userDTO
Panel --> User: Success

== Update User Flow ==

User -> Panel: update(userDTO)
Panel -> Service: update(id, userDTO)
Service -> Repository: save(user)

Repository -> Selector: selectStrategy(user)
Selector --> Repository: UserUpdateStrategy (id != null)

Repository -> Strategy: getSQL()
Strategy --> Repository: "UPDATE users SET..."

Repository -> Strategy: setParameters(user, stmt)
Repository -> Strategy: isInsert()

Repository -> Provider: getConnection()
Provider -> DB: getConnection()

Repository -> DB: executeUpdate(stmt)

Repository -> Strategy: postExecute(user, stmt)
note right: No ID extraction needed\nfor update

Repository --> Service: updatedUser
Service --> Panel: userDTO
Panel --> User: Success

@enduml