<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.medical.client.controller.AppointmentListController">
   
   <HBox alignment="CENTER_LEFT" spacing="10.0">
      <Label styleClass="title-label" text="Appointments Management" />
      <HBox HBox.hgrow="ALWAYS" />
      <Button styleClass="button-success" text="+ New" onAction="#handleCreateAppointment" />
      <Button styleClass="button-warning" text="Reschedule" onAction="#handleRescheduleAppointment" />
      <Button styleClass="button-danger" text="Cancel Apt." onAction="#handleCancelAppointment" />
      <Button styleClass="button-primary" text="Refresh" onAction="#loadAppointments" />
   </HBox>

   <HBox alignment="CENTER_LEFT" spacing="10.0">
      <Label text="Patient Document:" />
      <TextField fx:id="patientDocSearch" promptText="Document number" />
      <Button styleClass="button-primary" text="Search" onAction="#handleSearchByPatient" />
      <Button text="Clear" onAction="#loadAppointments" />
   </HBox>
   
   <TableView fx:id="appointmentTable" VBox.vgrow="ALWAYS">
     <columns>
       <TableColumn fx:id="idColumn" prefWidth="50.0" text="ID" />
       <TableColumn fx:id="patientColumn" prefWidth="140.0" text="Patient Name" />
       <TableColumn fx:id="doctorColumn" prefWidth="140.0" text="Doctor Name" />
       <TableColumn fx:id="dateColumn" prefWidth="100.0" text="Date" />
       <TableColumn fx:id="timeColumn" prefWidth="80.0" text="Time" />
       <TableColumn fx:id="durationColumn" prefWidth="70.0" text="Duration" />
       <TableColumn fx:id="statusColumn" prefWidth="100.0" text="Status" />
     </columns>
   </TableView>
   
   <Label fx:id="statusLabel" text="Ready" />
</VBox>
