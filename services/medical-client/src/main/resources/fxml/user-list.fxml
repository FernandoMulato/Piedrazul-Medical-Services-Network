<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.medical.client.controller.UserListController">
   
   <HBox alignment="CENTER_LEFT" spacing="20.0">
      <Label styleClass="title-label" text="Users Management" />
      <HBox HBox.hgrow="ALWAYS" />
      <Button styleClass="button-primary" text="Refresh" onAction="#loadUsers" />
   </HBox>
   
   <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
     <columns>
       <TableColumn fx:id="idColumn" prefWidth="50.0" text="ID" />
       <TableColumn fx:id="usernameColumn" prefWidth="150.0" text="Username" />
       <TableColumn fx:id="roleColumn" prefWidth="120.0" text="Role" />
       <TableColumn fx:id="activeColumn" prefWidth="100.0" text="Active" />
     </columns>
   </TableView>
   
   <Label fx:id="statusLabel" text="Ready" />
</VBox>
