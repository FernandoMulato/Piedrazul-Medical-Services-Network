<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.medical.client.controller.ClinicalRecordListController">
   
   <HBox alignment="CENTER_LEFT" spacing="10.0">
      <Label styleClass="title-label" text="Clinical Records" />
      <HBox HBox.hgrow="ALWAYS" />
      <Button styleClass="button-success" text="+ New Record" onAction="#handleCreateRecord" />
      <Button styleClass="button-warning" text="Edit" onAction="#handleEditRecord" />
      <Button styleClass="button-danger" text="Delete" onAction="#handleDeleteRecord" />
   </HBox>

   <HBox alignment="CENTER_LEFT" spacing="10.0">
      <Label text="Patient Document:" />
      <TextField fx:id="patientDocSearch" promptText="Enter patient document" />
      <Button styleClass="button-primary" text="Search" onAction="#handleSearch" />
   </HBox>
   
   <TableView fx:id="recordsTable" VBox.vgrow="ALWAYS">
     <columns>
       <TableColumn fx:id="idColumn" prefWidth="50.0" text="ID" />
       <TableColumn fx:id="patientDocColumn" prefWidth="120.0" text="Patient Document" />
       <TableColumn fx:id="professionalIdColumn" prefWidth="80.0" text="Prof. ID" />
       <TableColumn fx:id="diagnosisColumn" prefWidth="200.0" text="Diagnosis" />
       <TableColumn fx:id="treatmentColumn" prefWidth="200.0" text="Treatment" />
       <TableColumn fx:id="dateColumn" prefWidth="100.0" text="Date" />
     </columns>
   </TableView>
   
   <Label fx:id="statusLabel" text="Ready" />
</VBox>
