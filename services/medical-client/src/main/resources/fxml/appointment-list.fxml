<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.medical.client.controller.AppointmentListController">
   
   <HBox alignment="CENTER_LEFT" spacing="20.0">
      <Label styleClass="title-label" text="Appointments Management" />
      <HBox HBox.hgrow="ALWAYS" />
      <Button styleClass="button-primary" text="Refresh" onAction="#loadAppointments" />
   </HBox>
   
   <TableView fx:id="appointmentTable" VBox.vgrow="ALWAYS">
     <columns>
       <TableColumn fx:id="idColumn" prefWidth="50.0" text="ID" />
       <TableColumn fx:id="patientColumn" prefWidth="180.0" text="Patient Name" />
       <TableColumn fx:id="doctorColumn" prefWidth="180.0" text="Doctor Name" />
       <TableColumn fx:id="dateColumn" prefWidth="100.0" text="Date" />
       <TableColumn fx:id="statusColumn" prefWidth="120.0" text="Status" />
     </columns>
   </TableView>
   
   <Label fx:id="statusLabel" text="Ready" />
</VBox>
