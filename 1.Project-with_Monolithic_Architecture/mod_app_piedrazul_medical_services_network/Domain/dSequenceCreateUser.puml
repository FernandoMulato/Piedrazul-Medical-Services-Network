@startuml CreateUserSequence

actor Administrator

participant "CreateUserView\n(Presentación)" as View
participant "UserController\n(Presentación)" as Controller
participant "UserService\n(Aplicación)" as Service
participant "UserFactory\n(Dominio)" as Factory
participant "User\n(Dominio)" as User
participant "UserRepository\n(Infraestructura)" as Repository
database "SQLite DB" as DB

Administrator -> View : Completa formulario\n(username, role, datos)

View -> Controller : crearUsuario(datos)

Controller -> Service : crearUsuario(datos)

Service -> Factory : crearUsuarioSegunRol(datos)
Factory --> Service : instancia User

Service -> User : validarDatos()
User --> Service : OK / Error

Service -> Repository : verificarUsernameUnico(username)
Repository -> DB : SELECT username
DB --> Repository : resultado
Repository --> Service : disponible / no disponible

alt Username disponible
    Service -> Repository : guardar(user)
    Repository -> DB : INSERT user
    DB --> Repository : OK
    Repository --> Service : confirmación
    
    Service --> Controller : éxito
    Controller --> View : mostrarConfirmación()
else Username ya existe
    Service --> Controller : errorDuplicado
    Controller --> View : mostrarError()
end

@enduml