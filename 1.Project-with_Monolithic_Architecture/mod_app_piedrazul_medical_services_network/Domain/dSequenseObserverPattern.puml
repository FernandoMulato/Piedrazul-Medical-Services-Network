@startuml ObserverEventBusSequence

actor Usuario

participant "AppointmentView\n(Presentación)" as View
participant "AppointmentController\n(Presentación)" as Controller
participant "AppointmentService\n(Aplicación)" as Service
participant "ClsClinicEventBus\n(Observer - Subject)" as EventBus
participant "ClsClinicEvent\n(Evento)" as Event

participant "CalendarView\n(Observer)" as Calendar
participant "NotificationView\n(Observer)" as Notification
participant "DashboardView\n(Observer)" as Dashboard

== Suscripción de Observers ==

Calendar -> EventBus : subscribe(this)
Notification -> EventBus : subscribe(this)
Dashboard -> EventBus : subscribe(this)

== Flujo principal ==

Usuario -> View : Agendar cita

View -> Controller : solicitarAgendamiento(datos)
Controller -> Service : agendarCita(datos)

Service -> Service : crearCita()

Service -> Event : new ClsClinicEvent(\nCITA_AGENDADA, "Cita creada")

Service -> EventBus : publish(event)

loop por cada observer
    EventBus -> Calendar : onEvent(event)
    EventBus -> Notification : onEvent(event)
    EventBus -> Dashboard : onEvent(event)
end

Calendar -> Calendar : actualizarCalendario()
Notification -> Notification : mostrarNotificación()
Dashboard -> Dashboard : refrescarVista()

@enduml