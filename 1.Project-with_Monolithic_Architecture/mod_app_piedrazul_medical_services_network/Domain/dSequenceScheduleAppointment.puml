@startuml ScheduleAppointmentSequence

actor Usuario

participant "AppointmentView\n(Presentación)" as View
participant "AppointmentController\n(Presentación)" as Controller
participant "AppointmentService\n(Aplicación)" as Service
participant "AppointmentRepository\n(Infraestructura)" as Repository
database "SQLite DB" as DB

Usuario -> View : Completa formulario\n(paciente, teléfono, médico, fecha, motivo)

View -> Controller : listener → opSchedule()

Controller -> Controller : Valida campos del formulario
Controller -> Controller : resolveAttentionType(especialidad)
Controller -> Service : opSchedule(appointment)

Service -> Service : Valida campos obligatorios

Service -> Repository : opCheckScheduleConflict(medId, fechaHora)
Repository -> DB : SELECT COUNT(*) FROM APPOINTMENT\nWHERE APP_MED_ID=? AND APP_DATETIME=?\nAND APP_STATUS != 'CANCELLED'
DB --> Repository : count resultado
Repository --> Service : false (sin conflicto)

alt Sin conflicto de horario
    Service -> Repository : opCreate(appointment)
    Repository -> DB : INSERT INTO APPOINTMENT (...)
    DB --> Repository : generatedKey (attId)
    Repository --> Service : Appointment (con ID asignado)

    Service --> Controller : Appointment creada
    Controller -> View : showDialog("¡Cita agendada! ID: X")
    Controller -> Controller : opClearSchedule()
    Controller -> View : limpia campos del formulario
else Conflicto de horario
    Service --> Controller : IllegalStateException
    Controller -> View : showDialog("Error: conflicto de horario")
else Campo inválido
    Service --> Controller : IllegalArgumentException
    Controller -> View : showDialog("Error: campo inválido")
end

@enduml
