@startuml ReScheduleAppointmentSequence

actor Usuario

participant "AppointmentView\n(Presentación)" as View
participant "AppointmentController\n(Presentación)" as Controller
participant "AppointmentService\n(Aplicación)" as Service
participant "AppointmentRepository\n(Infraestructura)" as Repository
database "SQLite DB" as DB

== Búsqueda de la cita ==

Usuario -> View : Ingresa ID de la cita → "Buscar cita"

View -> Controller : listener → opSearchAppointment()
Controller -> Service : opFindAppointment(id)
Service -> Repository : opView(id)
Repository -> DB : SELECT * FROM APPOINTMENT WHERE APP_ID=?
DB --> Repository : ResultSet
Repository --> Service : Appointment existente
Service --> Controller : Appointment

Controller -> View : setScheduleInfoTableModel(model)
Controller -> View : pre-rellena campos (médico, fecha, motivo)

== Reagendamiento ==

Usuario -> View : Modifica fecha/hora o médico → "Reagendar Cita"

View -> Controller : listener → opReSchedule()

Controller -> Service : opReSchedule(patch)

Service -> Repository : opView(appointmentId)
Repository -> DB : SELECT * FROM APPOINTMENT WHERE APP_ID=?
DB --> Repository : ResultSet
Repository --> Service : Appointment existente

Service -> Repository : opCheckScheduleConflict(newMedId, nuevaFechaHora)
Repository -> DB : SELECT COUNT(*) FROM APPOINTMENT\nWHERE APP_MED_ID=? AND APP_DATETIME=?\nAND APP_STATUS != 'CANCELLED'
DB --> Repository : 0
Repository --> Service : false (sin conflicto)

Service -> Service : Actualiza fecha, médico\ny status = RESCHEDULED

Service -> Repository : opUpdate(appointment)
Repository -> DB : UPDATE APPOINTMENT SET ... WHERE APP_ID=?
DB --> Repository : rowsAffected > 0
Repository --> Service : true

alt Reagendamiento exitoso
    Service --> Controller : true
    Controller -> View : showDialog("¡Cita reagendada! Estado: REAGENDADA")
    Controller -> Controller : opClearReSchedule()
    Controller -> View : limpia campos del panel
else Conflicto de horario
    Service --> Controller : IllegalStateException
    Controller -> View : showDialog("Error: conflicto de horario")
else Cita no encontrada
    Service --> Controller : IllegalArgumentException
    Controller -> View : showDialog("Error: cita no encontrada")
end

@enduml
