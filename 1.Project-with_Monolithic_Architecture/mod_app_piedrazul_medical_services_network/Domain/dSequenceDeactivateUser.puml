@startuml DeactivateUserSequence
' E1-HU4: Como administrador, quiero desactivar usuarios
' Para tener control del acceso de los usuarios

actor Administrador

participant "MainFrame\n(Presentación)" as Frame
participant "UserController\n(Presentación)" as Controller
participant "UserService\n(Aplicación)" as Service
participant "UserRepository\n(Infraestructura)" as Repository
database "SQLite DB" as DB

Administrador -> Frame : Selecciona un usuario\nen la tabla y presiona "Desactivar"

Frame -> Frame : obtener userId\ndel usuario seleccionado

alt Ningún usuario seleccionado
    Frame --> Administrador : mostrarAdvertencia\n("Seleccione un usuario")
end

Frame -> Controller : opDeactivateUser(userId)

Controller -> Service : opDeactivateUser(userId)

Service -> Repository : opDeactivate(id)

Repository -> Repository : delega a opUpdateState(id, State.INACTIVE.getId())

Repository -> DB : UPDATE USER\nSET USER_STATE = ?\nWHERE USER_ID = ?
DB --> Repository : filas afectadas

alt Actualización exitosa
    Repository --> Service : true
    Service --> Controller : true
    Controller --> Frame : true
    Frame -> Controller : opList()
    Controller --> Frame : List<ClsUser> actualizada
    Frame -> Frame : recargar tabla
    Frame --> Administrador : Usuario desactivado correctamente\n(estado cambia a INACTIVE)
else No se encontró el usuario
    Repository --> Service : false
    Service --> Controller : false
    Controller --> Frame : false
    Frame --> Administrador : mostrarError\n("No se pudo desactivar el usuario")
end

note over Frame : El usuario desactivado ya no podrá\nacceder al sistema (opVerifyUser filtra\npor STATE_TYPE = 'ACTIVE')

@enduml
