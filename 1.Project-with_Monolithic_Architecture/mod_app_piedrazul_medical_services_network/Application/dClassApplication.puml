class UserService <<service>> #PaleGreen;line:Black;text:Black implements IUserService {}

' from domain layer
abstract User<Domain Layer> <<abstract>> #Pink;line:Black;line.dotted;text:gray {
  # id: long 
  # username: String
  # fullname: String
  # password: String
